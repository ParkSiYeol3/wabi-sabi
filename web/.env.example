# Supabase — 프로젝트 생성 후 Dashboard > Project Settings > API 에서 복사
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# 서버 전용 (RLS 우회, 절대 클라이언트 노출 금지) — 어드민 작업에서만 사용
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 어드민 허용 이메일 (콤마 구분) — /admin 접근 권한
ADMIN_EMAILS=admin@wasa.kr

# 토스페이먼츠 (개발자센터 test 키) — https://developers.tosspayments.com
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_xxxxx
TOSS_SECRET_KEY=test_sk_xxxxx

# 인스타그램 피드 (선택) — Meta 개발자 앱 > Instagram API 장기 액세스 토큰(60일 만료, 갱신 필요)
# 미설정 시 About 페이지 피드는 플레이스홀더로 표시됨
INSTAGRAM_ACCESS_TOKEN=

# 메일 발송 (권장) — Resend (https://resend.com), 주문 확인·배송 알림에 사용
# ⚠ 발신 도메인(wasa.kr)을 Resend 에 등록하고 DNS 인증까지 마쳐야 실제로 발송된다.
# 미설정 시 발송만 건너뛴다(결제·주문 흐름은 정상 동작).
RESEND_API_KEY=
EMAIL_FROM=WABI-SABI <noreply@wasa.kr>

# 네이버 지도 (권장) — 네이버 클라우드 플랫폼 > Maps > Application 등록 후 Client ID
# https://console.ncloud.com (Maps 는 무료 티어 제공, 웹 서비스 URL 에 배포 도메인 등록 필요)
# 미설정 시 지도 칸은 구글 지도 임베드로 폴백됨
NEXT_PUBLIC_NAVER_MAP_CLIENT_ID=

# Rate limit (선택) — Upstash Redis (Vercel Marketplace 로 프로비저닝 시 자동 주입)
# 미설정 시 인메모리 폴백으로 동작(인스턴스별 독립 = 상한이 느슨함). 운영에선 설정 권장.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
